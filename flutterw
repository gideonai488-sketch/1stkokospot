#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FLUTTER_BIN="$ROOT_DIR/.flutter-sdk/bin/flutter"

if [[ ! -x "$FLUTTER_BIN" ]]; then
  echo "Flutter SDK not found at $ROOT_DIR/.flutter-sdk"
  echo "Install it with: git clone --depth 1 https://github.com/flutter/flutter.git -b stable .flutter-sdk"
  exit 1
fi

exec "$FLUTTER_BIN" "$@"
